@inject IJSRuntime JS

<div class="hex-container" style="background-color: @BackgroundColor;">
    <svg width="100%" height="100%" viewBox="0 0 @(Columns * HorizontalSpacing) @(Rows * VerticalSpacing)">
        @for (int r = 0; r < Rows + 1; r++)
        {
            @for (int c = 0; c < Columns + 1; c++)
            {
                // Logic for "Glitch" - randomly skip rendering a hexagon
                if (Random.Shared.NextDouble() < GlitchChance) continue;

                double x = c * HorizontalSpacing;
                double y = r * VerticalSpacing;
                if (c % 2 != 0) { y += VerticalSpacing / 2; }

                // Logic for "Fade" - randomized opacity for a textured look
                double opacity = 0.2 - (Random.Shared.NextDouble() * FadeVariation * 0.2);

                @* Inside the loop *@
                <polygon points="@GetPoints(x, y)" 
                         class="hex-tile"
                         fill="@FillColor" 
                         stroke="@StrokeColor" 
                         stroke-width="@StrokeWidth"
                         stroke-opacity="@opacity.ToString("F2")" />

                <style>
                    .hex-container {
                        width: 100vw; height: 100vh;
                        overflow: hidden; position: fixed;
                        top: 0; left: 0; z-index: -1;
                    }
                
                    .hex-tile {
                        transition: all 0.3s ease; /* Smooth fade in/out */
                        pointer-events: all;       /* Ensure SVG accepts mouse events */
                    }
                
                    /* The "Light Up" Effect */
                    .hex-tile:hover {
                        fill: rgba(0, 0, 0, 0.1);    /* Subtle grey fill on hover */
                        stroke-opacity: 0.5 !important; /* Make the border fully solid */
                        stroke-width: 2;             /* Slightly thicken the line */
                    }
                </style>
            }
        }
    </svg>
</div>

@code {
    [Parameter] public int Rows { get; set; } = 25;
    [Parameter] public int Columns { get; set; } = 40;
    [Parameter] public double HexSize { get; set; } = 20;
    [Parameter] public double StrokeWidth { get; set; } = 1;
    [Parameter] public string BackgroundColor { get; set; } = "#ffffff";
    [Parameter] public string FillColor { get; set; } = "none";
    [Parameter] public string StrokeColor { get; set; } = "#000000";

    /* NEW PROCEDURAL PARAMETERS */
    // 0.0 = none, 1.0 = all gone. Try 0.05 for a subtle "broken" look.
    [Parameter] public double GlitchChance { get; set; } = 0.05; 
    
    // 0.0 = solid black, 1.0 = full range of light to dark.
    [Parameter] public double FadeVariation { get; set; } = 0.4;

    private double HorizontalSpacing => HexSize * 1.5;
    private double VerticalSpacing => HexSize * Math.Sqrt(3);

    private string GetPoints(double centerX, double centerY)
    {
        var points = new List<string>();
        for (int i = 0; i < 6; i++)
        {
            double angleRad = Math.PI / 180 * (60 * i);
            points.Add($"{(centerX + HexSize * Math.Cos(angleRad)):F2},{(centerY + HexSize * Math.Sin(angleRad)):F2}");
        }
        return string.Join(" ", points);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Set up the JS listener
            await JS.InvokeVoidAsync("onBrowserResize", DotNetObjectReference.Create(this));
            
            // Initial size get
            var size = await JS.InvokeAsync<WindowSize>("getWindowSize");
            UpdateGrid(size.Width, size.Height);
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnWindowResize(int width, int height)
    {
        UpdateGrid(width, height);
        StateHasChanged(); // Force re-render with new hex count
    }

    private void UpdateGrid(int width, int height)
    {
        Columns = (int)(width / HorizontalSpacing) + 1;
        Rows = (int)(height / VerticalSpacing) + 1;
    }

    public class WindowSize { public int Width { get; set; } public int Height { get; set; } }
}

<style>
    .hex-container {
        width: 100vw; height: 100vh;
        overflow: hidden; position: fixed;
        top: 0; left: 0; z-index: -1;
    }
</style>
