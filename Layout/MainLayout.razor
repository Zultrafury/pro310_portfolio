@inherits LayoutComponentBase
@inject NavigationManager Nav
@using PortfolioWebsite.Components
@implements IDisposable

<VcrOverlay ShowTimecode="true">
    <HexGrid Rows="25"
             Columns="40"
             HexSize="25"
             StrokeWidth="4"
             GlitchChance="0.5"
             FadeVariation="0.5"
             StrokeColor="var(--primary)"
             BackgroundColor="var(--secondary)"/>
    <div class="invert centercontainer navbar">
        <h3>Zultrafury</h3>
        <a href="">Home</a>
        <a href="Projects">Projects</a>
        <a href="About">About</a>
        <a href="Contact">Contact</a>
    </div>
    <div class="page-container @(_animClass)">
        
        @Body

        <footer></footer>
    </div>
</VcrOverlay>

@code {
    private string _animClass = "page-enter"; // Initial entry
    private bool _isProcessing = false;
    private IDisposable? _navSubscription;

    protected override void OnInitialized()
    {
        _navSubscription = Nav.RegisterLocationChangingHandler(HandleLocationChanging);
    }

    private async ValueTask HandleLocationChanging(LocationChangingContext context)
    {
        if (_isProcessing) return;

        context.PreventNavigation();
        _isProcessing = true;

        // 1. Trigger Exit Animation
        _animClass = "page-exit";
        StateHasChanged();

        // 2. Wait for exit to finish
        await Task.Delay(300); 

        // 3. Reset to neutral state BEFORE navigating 
        // This prevents the new page from inheriting "page-exit" styles
        _animClass = "page-loading-hidden"; 
        StateHasChanged();
        
        // Small yield to let the browser process the hidden state
        await Task.Delay(10);

        // 4. Perform the actual navigation
        Nav.NavigateTo(context.TargetLocation);

        // 5. Trigger Entrance Animation for the next page
        _animClass = "page-enter";
        _isProcessing = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => _navSubscription?.Dispose();
}